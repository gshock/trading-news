# Azure Communication Services Email
ACS_CONNECTION_STRING=endpoint=https://<your-resource>.unitedstates.communication.azure.com/;accesskey=your-access-key
ACS_SENDER_ADDRESS=DoNotReply@<your-domain>.azurecomm.net

# Azure Blob Storage (read – used to build public image URLs in emails)
BLOB_STORAGE_BASE_URL=https://<your-storage-account>.blob.core.windows.net/<container>

# Azure Blob Storage (write – used by the ORB agent to upload chart images)
# Option A: connection string (local dev / CI)
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=<your-account>;AccountKey=<your-key>;EndpointSuffix=core.windows.net
# Option B: account URL + DefaultAzureCredential (managed identity in Azure)
# AZURE_STORAGE_ACCOUNT_URL=https://<your-storage-account>.blob.core.windows.net

# Azure Table Storage (for local development only)
# In Azure Container Apps, managed identity is used automatically
# AZURE_STORAGE_ACCOUNT_NAME=mrtraderstore6111dev
# AZURE_STORAGE_ACCOUNT_KEY=your-dev-storage-account-key
# AZURE_TABLE_NAME=subscriptions

# Server Configuration
PORT=3000
FRONTEND_URL=http://localhost:5173
API_URL=http://localhost:3000/api/v1

# API Key for the /send-mail endpoint (required)
# Generate a strong random value, e.g.: openssl rand -hex 32
SEND_MAIL_API_KEY=your-secret-api-key

# Agents
FOUNDRY_PROJECT_ENDPOINT=https://<your-resource>.services.ai.azure.com/api/projects/<project-id>
FOUNDRY_MODEL_DEPLOYMENT_NAME=gpt-4o
ENABLE_SCHEDULER=true
# Get this from: Azure AI Foundry portal -> your project -> Settings -> Keys and Endpoints
FOUNDRY_API_KEY=your-foundry-api-key

PROMPT_ENV=dev